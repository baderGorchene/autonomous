# .env.example
# This file lists the environment variables required by the BookSlot application.
# Create a .env file in the project root based on this example and fill in the actual values.

# FastAPI application settings
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External Service API Keys
# SendGrid for email notifications
SENDGRID_API_KEY="YOUR_SENDGRID_API_KEY"

# Twilio for WhatsApp notifications
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"
TWILIO_WHATSAPP_NUMBER="whatsapp:+1234567890" # Your Twilio WhatsApp enabled number

# Gemini API Key (for future AI features, currently not actively used)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"