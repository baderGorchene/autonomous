# Secret key for JWT token encoding
SECRET_KEY="your-super-secret-key-for-jwt"

# Algorithm for JWT (e.g., HS256)
ALGORITHM="HS256"

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SendGrid API Key for email notifications
SENDGRID_API_KEY="your-sendgrid-api-key"

# Twilio Account SID for WhatsApp notifications
TWILIO_ACCOUNT_SID="your-twilio-account-sid"

# Twilio Auth Token for WhatsApp notifications
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Twilio WhatsApp enabled phone number (e.g., whatsapp:+1XXXXXXXXXX)
TWILIO_WHATSAPP_NUMBER="whatsapp:+1XXXXXXXXXX"

# Google Gemini API Key for AI integrations (if applicable)
GEMINI_API_KEY="your-gemini-api-key"
